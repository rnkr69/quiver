# ─────────────────────────────────────────────────────────────
# Quiver — variables de entorno requeridas
# Copia este fichero a .env y rellena los valores reales.
# NUNCA commitas .env al repositorio.
# ─────────────────────────────────────────────────────────────

# Clave secreta para firmar JWT. Genera una con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-me

# URL de conexión a la base de datos.
# SQLite (desarrollo):
DATABASE_URL=sqlite:///./quiver.db
# PostgreSQL (producción):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/quiver_db

# Entorno de ejecución: development | production
QUIVER_ENV=development

# Prefijo de rutas de Quiver en la app FastAPI
QUIVER_PREFIX=/quiver/v1

# Roles del portal de acceso público (separados por comas)
# Ejemplo: QUIVER_PORTAL_ROLES=viewer,editor
QUIVER_PORTAL_ROLES=

# URL base del frontend (para construir links en emails)
QUIVER_FRONTEND_URL=http://localhost:5173
