# Base path the SPA is served from. Must match the backend mount path
# (QUIVER_FRONTEND_PATH, default /quiver). Keep the trailing slash.
VITE_BASE_PATH=/quiver/

# Base URL of the Quiver backend API. Lives under the base path above.
VITE_API_BASE_URL=/quiver/v1

# Comma-separated roles allowed into the client portal (/portal/*).
# Leave empty to disable the portal. Example: client,partner
VITE_PORTAL_ROLES=
