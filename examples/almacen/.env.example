# Copia este fichero como .env y ajusta los valores

# Genera una clave con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-cambia-esto-en-produccion

# SQLite para desarrollo — no requiere instalación adicional
DATABASE_URL=sqlite:///./almacen.db

# Entorno
QUIVER_ENV=development

# URL del frontend (Vite dev server)
QUIVER_FRONTEND_URL=http://localhost:5173

# Roles de portal (no se usa en este ejemplo, pero requerido si QUIVER_PORTAL_ROLES está vacío)
QUIVER_PORTAL_ROLES=
